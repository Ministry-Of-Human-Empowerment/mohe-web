# ── NextAuth (Auth.js v5) ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth App — Cavino creates this at:
# https://github.com/organizations/Ministry-Of-Human-Empowerment/settings/applications/new
#
# Application name:        MOHE Admin
# Homepage URL:            http://localhost:3000
# Authorization callback:  http://localhost:3000/api/auth/callback/github
#                          https://<vercel-url>/api/auth/callback/github  (add for prod)
#
# Both Steph and Cavino use the SAME Client ID + Secret.
# Each person signs in with their own GitHub account — no separate apps needed.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── GitHub API ──────────────────────────────────────────────────────────────
# Server-side PAT — fallback for unauthenticated server reads.
# Required scopes: Pull requests (read), Contents (read), Commit statuses (read)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_ORG=Ministry-Of-Human-Empowerment
GITHUB_REPO=mohe-web

