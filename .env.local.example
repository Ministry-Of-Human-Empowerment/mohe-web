# ── NextAuth (Auth.js v5) ───────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth App — create at: https://github.com/organizations/Ministry-Of-Human-Empowerment/settings/applications/new
# Homepage URL: https://yourdomain.com
# Callback URL: https://yourdomain.com/api/auth/callback/github  (or http://localhost:3000/api/auth/callback/github for dev)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── GitHub API ──────────────────────────────────────────────────────────────
# PAT with repo scope on Ministry-Of-Human-Empowerment org
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_ORG=Ministry-Of-Human-Empowerment
GITHUB_REPO=mohe-web

